#include <zephyr/dt-bindings/gpio/gpio.h>

/ {
	leds {
		compatible = "gpio-leds";
		user_led: led_0 {
			gpios = <&main_gpio1_0 17 GPIO_ACTIVE_HIGH>;
			label = "User LED GPIO6";
		};
	};

	aliases {
		led0 = &user_led;
	};
};

&main_gpio1_0 {
	status = "okay";
	pinctrl-0 = <&hat_31_gpio>;
	pinctrl-names = "default";
};